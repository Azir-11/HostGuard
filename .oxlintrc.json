{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import"],
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "src-tauri",
    "src/types/auto-imports.d.ts",
    "src/types/components.d.ts"
  ]
}
